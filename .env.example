# .env.example — шаблон настроек Гордона.
# СКОПИРУЙ В .env И ЗАПОЛНИ. .env НЕ КОММИТИТСЯ (секреты!).

# --- Аккаунты для отправки (spare Gmail). Ротируются по очереди. ---
# Для Gmail нужен APP PASSWORD (не обычный пароль):
#   https://myaccount.google.com/apppasswords
# Можно добавить сколько угодно ACCOUNT_N_EMAIL / ACCOUNT_N_PASS.
# ЧЕМ БОЛЬШЕ АККАУНТОВ — тем ниже риск бана (лимит ~500 писем/день на 1 акк,
# но безопаснее гнать ~5-10 писем с аккаунта, распределяя нагрузку).
# Пример на 50 писем/день: 5-10 аккаунтов (~5-10 писем каждый).
ACCOUNT_1_EMAIL=spare1@gmail.com
ACCOUNT_1_PASS=xxxx app password xxxx
ACCOUNT_2_EMAIL=spare2@gmail.com
ACCOUNT_2_PASS=xxxx app password xxxx
ACCOUNT_3_EMAIL=spare3@gmail.com
ACCOUNT_3_PASS=xxxx app password xxxx

# --- Лимиты отправки (защита от бана) ---
MAX_PER_DAY=50         # писем в сутки (суммарно по всем аккаунтам)
SEND_INTERVAL_SEC=30   # пауза между письмами в одном прогоне (запасная)
SLEEP_BETWEEN_ACCOUNTS_SEC=8  # пауза при смене аккаунта
HOURS=9-21             # окно отправки (локальное время)

# --- Разогрев (warm-up): первые N дней лимит ниже, потом плавно до MAX_PER_DAY ---
# 0 = сразу на полный лимит. Рекомендую 5-7 дней для новых аккаунтов.
WARMUP_DAYS=5

# --- Частота планировщика (для расчёта MAX_PER_RUN): прогонов в сутки ---
# Task Scheduler стоит hourly = 24. Если меняешь частоту — поправь тут.
RUNS_PER_DAY=24

# --- Разброс отправки (чтобы НЕ выглядело как спам-рассылка) ---
# Письма в рамках часа уходят в СЛУЧАЙНЫЕ минуты, а не пачкой в начале часа.
MIN_GAP_SEC=20         # мин. пауза между письмами (сек)
MAX_GAP_SEC=900        # макс. пауза между письмами (сек) — ~15 мин
RANDOM_START_SEC=600   # первое письмо тоже с случайной задержкой 0..600 сек (~10 мин)

# --- SMTP (Gmail по умолчанию) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
FROM_NAME=Nazar

# --- Опционально: IMAP-поллинг ответов (по умолчанию ВЫКЛ) ---
IMAP_ENABLED=false
# Если true — recorder заходит в INBOX каждого аккаунта и сам видит,
# кто ответил (сверяет отправителя с email из БД). Ставит статус replied.
# Требует включённый IMAP в настройках Gmail аккаунта.
IMAP_LOOKBACK_DAYS=14   # за сколько дней назад искать ответы
